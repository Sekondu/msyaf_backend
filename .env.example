# ── Required ──────────────────────────────────────────────
# Supabase Postgres connection string (use the DIRECT connection for migrations).
DATABASE_URL="postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres"
# Long random secret for signing JWTs.
JWT_SECRET="change-me-to-a-long-random-string"

# ── Optional ──────────────────────────────────────────────
# Railway injects PORT automatically; only set for local dev.
PORT=3000
# Comma-separated allowed origins, or "*".
CORS_ORIGIN="http://localhost:5173"

# ── S3-compatible media storage (optional until uploads are used) ──
# Leave blank to deploy without media; the media routes return 503 until set.
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_PUBLIC_URL=""
